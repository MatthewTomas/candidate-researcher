# Branch Playground — Environment Variables
# Copy this file to .env and fill in your keys.
# .env is gitignored and will NOT be committed.
#
# Vite exposes these as import.meta.env.VITE_*
# Only variables prefixed with VITE_ are available in the browser.

# Google AI Studio key (used for both gemini-free and gemini-paid)
VITE_GEMINI_API_KEY=

# Anthropic (Claude)
VITE_ANTHROPIC_API_KEY=

# OpenAI
VITE_OPENAI_API_KEY=

# xAI (Grok)
VITE_XAI_API_KEY=

# DeepSeek
VITE_DEEPSEEK_API_KEY=

# Hugging Face
VITE_HUGGINGFACE_API_KEY=

# Qwen (Alibaba)
VITE_QWEN_API_KEY=

# MiniMax
VITE_MINIMAX_API_KEY=
